# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# tests
coverage/

# Claude Code local settings
.claude/

# ------------------------------------------------------------------
# PRIVACY: real credit card statements live in fixtures/private/ and
# must NEVER be committed. The pre-commit hook in .githooks/ enforces
# the same rule. Only anonymized fixtures under fixtures/public/ are
# allowed into the repo.
# ------------------------------------------------------------------
fixtures/private/*
!fixtures/private/.gitkeep
*.pdf
